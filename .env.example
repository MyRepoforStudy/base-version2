DATABASE_URL="postgresql://serverinv:serverinv@localhost:5432/server_inventory?schema=public"

ZABBIX_API_URL="https://zabbix.example.com/zabbix/api_jsonrpc.php"
ZABBIX_API_TOKEN="your-zabbix-api-token"

# Corporate proxy - only needed if the build server has no direct
# internet access to registry.npmjs.org. Used as Docker build args only,
# cleared again for the running container. See docker-compose.yml.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
