DATABASE_URL=postgresql+psycopg://server_inventory:server_inventory@localhost:5432/server_inventory
APP_NAME=Linux Server Inventory
APP_ENV=local
APP_TIMEZONE=Asia/Almaty
SESSION_SECRET=change-this-session-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password

ZABBIX_URL=https://zabbix.example.local
ZABBIX_API_TOKEN=replace-with-zabbix-api-token
ZABBIX_VERIFY_SSL=true
ZABBIX_CA_FILE=
ZABBIX_HOST_GROUP=Linux servers
ZABBIX_AUTO_REFRESH_SECONDS=300

# Corporate proxy - only needed if the build server has no direct
# internet access to pypi.org. Used as Docker build args only.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
